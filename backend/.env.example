# ── Security ───────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Model ──────────────────────────────────────────────────
# Place your exported marine_model.keras file in backend/ml/
MODEL_PATH=ml/marine_model.keras
# Place class_indices.json (exported from Colab) in backend/ml/
CLASS_INDICES_PATH=ml/class_indices.json
# Must match the image size used during training (224 for MobileNetV2)
IMAGE_SIZE=224
# Normalization: "divide" for /255. or "mobilenet" for preprocess_input
PREPROCESS_MODE=divide

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./marine.db

# ── Storage ────────────────────────────────────────────────
UPLOAD_DIR=uploads
